NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://aman:aman@db:5432/aman?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# OTP (SMS provider)
OTP_PROVIDER=mock        # mock | twilio | unifonic
OTP_PROVIDER_KEY=
OTP_FROM=Aman
OTP_TTL_SECONDS=300

# USDT
USDT_WEBHOOK_SECRET=change-me-webhook
USDT_TRC20_DEPOSIT_ADDRESS=
USDT_ERC20_DEPOSIT_ADDRESS=

# Storage (KYC docs, receipts)
S3_ENDPOINT=
S3_BUCKET=aman-kyc
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Admin bootstrap
BOOTSTRAP_ADMIN_PHONE=+963999999999
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe#123
